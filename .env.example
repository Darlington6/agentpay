# Owner's private key (your wallet private key)
PRIVATE_KEY=your_wallet_private_key

# Agent's private key (the AI agent's wallet private key)
AGENT_PRIVATE_KEY=your_agent_wallet_private_key

# RPC URLs
LOCAL_RPC_URL=http://127.0.0.1:8545
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification (get from basescan.org)
BASESCAN_API_KEY=your_basescan_api_key

# Synthesis hackathon API key
SYNTHESIS_API_KEY=your_synthesis_api_key

# Contract address (filled in after deployment)
CONTRACT_ADDRESS=
NEXT_PUBLIC_CONTRACT_ADDRESS=
